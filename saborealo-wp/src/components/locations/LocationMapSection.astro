---
import type { LocationDetail } from "@/components/locations/types"
import { PannaSectionNotch } from "@/components/site/PannaSectionNotch"

interface Props {
	background: string
	location: LocationDetail
}

const { background, location } = Astro.props
const titleId = `${location.slug}-map-title`
---

<section
	class="location-map"
	style={`--location-map-background: url("${background}")`}
	aria-labelledby={titleId}
>
	<PannaSectionNotch className="location-map__notch" />

	<div class="panna-shell location-map__inner">
		<div class="location-map__embed">
			<iframe
				src={location.mapEmbedUrl}
				title={location.mapTitle}
				aria-label={location.mapTitle}
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
			></iframe>
		</div>

		<h2 id={titleId} class="location-map__title">
			{location.mapTagline}
		</h2>
	</div>
</section>
