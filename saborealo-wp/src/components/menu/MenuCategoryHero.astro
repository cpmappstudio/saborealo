---
import PannaTextHero from "@/components/site/PannaTextHero.astro";
import type { PannaMenuCategoryPage } from "@/data/panna-menu";

interface Props {
	category: PannaMenuCategoryPage;
	background: string;
}

const { category, background } = Astro.props;
---

<PannaTextHero
	background={background}
	title={category.title}
	titleId="menu-category-title"
/>
