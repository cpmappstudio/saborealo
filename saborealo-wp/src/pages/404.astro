---
import SiteLayout from "@/layouts/SiteLayout.astro"

Astro.response.status = 404
---

<SiteLayout
	title="Page not found — Saborealo Bakery"
	description="The page you're looking for doesn't exist or has been moved."
>
	<section class="not-found-page">
		<div class="panna-shell not-found-page__inner">
			<p class="not-found-page__code">404</p>
			<h1 class="not-found-page__title">Page not found</h1>
			<p class="not-found-page__copy">
				The page you're looking for doesn't exist or has been moved.
			</p>
			<a class="not-found-page__link" href="/">← Back to home</a>
		</div>
	</section>
</SiteLayout>
