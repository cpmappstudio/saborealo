---
import { MenuBackLink } from "@/components/menu/MenuBackLink"
import {
	MenuItemDetail,
	type MenuItemDetailData,
} from "@/components/menu/MenuItemDetail"
import { imageUrl } from "@/lib/sanity/image"
import {
	MENU_ITEM_PAGE_QUERY,
	MENU_ITEM_SLUGS_QUERY,
} from "@/lib/sanity/queries"
import SiteLayout from "@/layouts/SiteLayout.astro"
import { sanityClient } from "sanity:client"

export async function getStaticPaths() {
	const items = await sanityClient.fetch(MENU_ITEM_SLUGS_QUERY)
	return items
		.filter((entry) => entry.slug && entry.categorySlug)
		.map((entry) => ({
			params: {
				category: entry.categorySlug as string,
				item: entry.slug as string,
			},
		}))
}

const { category: categorySlug, item: itemSlug } = Astro.params

const item = await sanityClient.fetch(MENU_ITEM_PAGE_QUERY, {
	categorySlug,
	itemSlug,
})

if (!item || !item.image) {
	return Astro.redirect(`/menu/${categorySlug}/`)
}

const product: MenuItemDetailData = {
	title: item.title ?? "",
	description: item.description ?? "",
	rating: item.rating ?? 0,
	image: {
		src: imageUrl(item.image, { width: 800, height: 800 }),
		alt: item.image.alt ?? item.title ?? "",
	},
	orderUrl: item.orderUrl ?? "",
}
---

<SiteLayout
	title={`${product.title} | PANNA`}
	description={product.description}
>
	<div class="menu-item-page">
		<MenuItemDetail product={product} />
		<MenuBackLink href={`/menu/${categorySlug}/`} label="GO BACK" />
	</div>
</SiteLayout>
