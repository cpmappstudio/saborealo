---
import { MenuBackLink } from "@/components/menu/MenuBackLink"
import MenuCategoryHero from "@/components/menu/MenuCategoryHero.astro"
import {
	MenuProductGrid,
	type MenuProductCard,
} from "@/components/menu/MenuProductGrid"
import { pannaSectionAssets } from "@/data/panna-section-assets"
import { imageUrl } from "@/lib/sanity/image"
import { MENU_CATEGORY_PAGE_QUERY } from "@/lib/sanity/queries"
import SiteLayout from "@/layouts/SiteLayout.astro"
import { sanityClient } from "sanity:client"

const { category: categorySlug } = Astro.params

const category = await sanityClient.fetch(MENU_CATEGORY_PAGE_QUERY, {
	slug: categorySlug,
})

if (!category) {
	return Astro.redirect("/menu/")
}

const products: MenuProductCard[] = (category.items ?? [])
	.filter((item) => item.slug && item.image)
	.map((item) => ({
		id: item._id,
		slug: item.slug as string,
		title: item.title ?? "",
		image: {
			src: imageUrl(item.image!, { width: 800, height: 800 }),
			alt: item.image?.alt ?? item.title ?? "",
		},
	}))
---

<SiteLayout
	title={`${category.label} | PANNA`}
	description={`Explore PANNA ${category.label?.toLowerCase()} menu items and details.`}
>
	<div class="menu-category-page">
		<MenuCategoryHero
			title={category.label ?? ""}
			background={pannaSectionAssets.menu.categoryHero.background}
		/>
		<MenuProductGrid
			title={category.label ?? ""}
			categorySlug={category.slug as string}
			products={products}
		/>
		<MenuBackLink href="/menu/" label="GO BACK" />
	</div>
</SiteLayout>
