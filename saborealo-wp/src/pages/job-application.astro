---
import { actions, isInputError } from "astro:actions";

import { JobApplicationPage } from "@/components/job-application/JobApplicationPage";
import { pannaJobApplicationData } from "@/data/panna-job-application";
import SiteLayout from "@/layouts/SiteLayout.astro";

// SSR — Astro Actions need the page to handle POST requests; prerendered
// pages serve static HTML and the action handler never runs.
export const prerender = false;

const result = Astro.getActionResult(actions.submitJobApplication);
if (result?.data) {
    return Astro.redirect("/job-application/");
}
if (result?.error) {
    console.error("[submitJobApplication]", result.error);
}

const inputErrors = isInputError(result?.error) ? result.error.fields : {};
---

<SiteLayout
    title="Job Application - Saborealo Bakery"
    description="Apply to join the Saborealo Bakery team."
>
    <JobApplicationPage
        jobApplication={pannaJobApplicationData}
        action={String(actions.submitJobApplication)}
        inputErrors={inputErrors}
    />
</SiteLayout>
